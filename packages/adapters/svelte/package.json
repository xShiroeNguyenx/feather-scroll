{
  "name": "@feather-scroll/svelte",
  "version": "0.1.0",
  "description": "Svelte action for FeatherScroll.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@feather-scroll/core": "workspace:*"
  },
  "devDependencies": {
    "@feather-scroll/core": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xShiroeNguyenx/feather-scroll.git",
    "directory": "packages/adapters/svelte"
  },
  "homepage": "https://github.com/xShiroeNguyenx/feather-scroll#readme",
  "bugs": {
    "url": "https://github.com/xShiroeNguyenx/feather-scroll/issues"
  }
}
