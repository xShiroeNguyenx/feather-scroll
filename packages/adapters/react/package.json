{
  "name": "@feather-scroll/react",
  "version": "0.1.0",
  "description": "React component for FeatherScroll.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "publishConfig": { "access": "public" },
  "peerDependencies": {
    "@feather-scroll/core": "workspace:*",
    "react": ">=17"
  },
  "devDependencies": {
    "@feather-scroll/core": "workspace:*",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
